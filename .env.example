# Runtime
NODE_ENV=development
API_PORT=3000

# Dev API behavior
DEV_API_WARMUP=false
DEV_API_DEBUG_LOGS=false

# Rate limiting
RATE_LIMIT_MODE=redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Frontend debug logs
VITE_DEBUG_LOGS=false

# Database
DATABASE_URL=
DB_POOL_MAX=4
DB_STATEMENT_TIMEOUT_MS=20000

# Auth
AUTH_SESSION_SECRET=
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Contact / Email
RESEND_API_KEY=
CONTACT_FROM_EMAIL=
CONTACT_TO_EMAIL=
