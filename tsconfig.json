{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "types": [
      "node",
      "vite/client"
    ]
  },
  "include": [
    "src",
    "api",
    "lib",
    "vite.config.js",
    "eslint.config.js",
    "tests"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
